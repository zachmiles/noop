      }
    },
    "No data for today. Was your strap worn and connected overnight?" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Keine Daten für heute. Wurde Ihr Armband über Nacht getragen und angeschlossen?"
          }
