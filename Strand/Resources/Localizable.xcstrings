            "state" : "translated",
            "value" : "Сначала подключите ремешок — для чтения необходим прямой поток R-R."
          }
        }
      }
    },
    "Connect your strap first." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Schließen Sie zuerst Ihren Gurt an."
          }
