            "value" : "NOOP"
          }
        }
      }
    },
    "NOOP — all your data, none of the cloud." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NOOP — all deine Daten, nichts in der Cloud."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NOOP — all your data, none of the cloud."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NOOP: todos tus datos, nada de la nube."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NOOP — все ваши данные, без облачных сервисов."
          }
        }
      }
    },
    "NOOP %@" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NOOP %@"
          }
        },
        "en" : {
          "stringUnit" : {
