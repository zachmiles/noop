          "stringUnit" : {
            "state" : "translated",
            "value" : "Duplicar como manual…"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Дублировать как вручную…"
          }
        }
      }
    },
    "Duration" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dauer"
          }
        },
        "es" : {
