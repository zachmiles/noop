          }
        }
      }
    },
    "Connect your strap for haptic guidance — you'll feel one pulse on the inhale, two on the exhale, so you can breathe with your eyes closed." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbinde deinen Strap für haptische Führung — du spürst einen Impuls beim Einatmen, zwei beim Ausatmen, sodass du mit geschlossenen Augen atmen kannst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Connect your strap for haptic guidance — you'll feel one pulse on the inhale, two on the exhale, so you can breathe with your eyes closed."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecte su correa para obtener guía háptica: sentirá un pulso al inhalar y dos al exhalar, para que pueda respirar con los ojos cerrados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подключите браслет, чтобы он подсказывал ритм вибрацией: один импульс на вдохе, два — на выдохе. Так можно дышать с закрытыми глазами."
          }
        }
      }
    },
    "Connect your strap for the felt cue — the sweep paces you with one buzz on the inhale, two on the exhale." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Befestigen Sie Ihren Gurt für den Filz-Queue – der Schwung bewegt Sie mit einem Summton beim Einatmen und zwei Summschlägen beim Ausatmen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecte su correa para la señal sentida: el barrido lo marca con un zumbido al inhalar y dos al exhalar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подсоедините ремешок к фетровому кию — подсечка будет выполняться с одним жужжанием на вдохе и двумя на выдохе."
          }
        }
      }
    },
