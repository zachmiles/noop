    "Low confidence" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Geringes Vertrauen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Baja confianza"
          }
        },
