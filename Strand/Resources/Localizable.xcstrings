    "Acts as a standard Bluetooth heart-rate strap. Pair NOOP from your treadmill, bike or app to see your strap's heart rate there." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fungiert als Standard-Bluetooth-Herzfrequenzgurt. Koppeln Sie NOOP mit Ihrem Laufband, Fahrrad oder Ihrer App, um dort die Herzfrequenz Ihres Gurtes anzuzeigen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Actúa como una correa de frecuencia cardíaca Bluetooth estándar. Empareje NOOP desde su cinta de correr, bicicleta o aplicación para ver allí la frecuencia cardíaca de su correa."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Действует как стандартный пульсометр Bluetooth. Подключите NOOP к беговой дорожке, велосипеду или приложению, чтобы увидеть частоту пульса вашего ремня."
          }
        }
      }
    },
    "Acute (7-day) vs chronic (28-day) training load. 0.8–1.3 is the sweet spot." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Akute (7 Tage) vs. chronische (28 Tage) Trainingslast. 0,8–1,3 ist der ideale Bereich."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Acute (7-day) vs chronic (28-day) training load. 0.8–1.3 is the sweet spot."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Carga de entrenamiento aguda (7 días) versus crónica (28 días). 0,8–1,3 es el punto óptimo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Соотношение острой (7-дневной) и хронической (28-дневной) тренировочной нагрузки. Оптимальный коэффициент — 0,8–1,3."
          }
        }
      }
    },
