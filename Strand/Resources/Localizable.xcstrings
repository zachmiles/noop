          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вчерашний синтез"
          }
        }
      }
    },
    "You removed your active strap. Choose which paired band provides your live data, or leave none active and pair one later." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben Ihren Aktivgurt entfernt. Wählen Sie aus, welches gekoppelte Band Ihre Live-Daten bereitstellt, oder lassen Sie keines aktiv und koppeln Sie später eines."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Te quitaste la correa activa. Elija qué banda emparejada proporciona sus datos en vivo o no deje ninguna activa y vincule una más tarde."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы сняли активный ремешок. Выберите, какой из парных диапазонов предоставляет вам данные в реальном времени, или не оставляйте ни один активный и подключите его позже."
          }
        }
      }
    },
    "You said: %@" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du sagtest: %@"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You said: %@"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dijiste:%@"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы сказали: %@"
          }
        }
      }
    },
    "You'll be reminded around %@." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie werden an%@ erinnert."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Se le recordará sobre%@."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вам напомнят о%@."
          }
        }
      }
    },
    "You'll likely wake around %lld ± %lld Charge if you sleep about %@ tonight." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie werden wahrscheinlich um%1$lld ±%2$lld Charge aufwachen, wenn Sie heute Nacht um%3$@ schlafen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You'll likely wake around %1$lld ± %2$lld Charge if you sleep about %3$@ tonight."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Probablemente te despertarás alrededor de%1$lld ±%2$lld Charge si duermes alrededor de%3$@ esta noche."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Скорее всего, вы проснетесь около%1$lld ±%2$lld Charge, если сегодня ночью будете спать около%3$@."
          }
        }
      }
    },
    "You're all caught up." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ihr seid alle beschäftigt."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Estáis todos atrapados."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Вы все в плену."
          }
        }
      }
    },
    "You're connected." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du bist verbunden."
          }
        },
        "en" : {
          "stringUnit" : {
