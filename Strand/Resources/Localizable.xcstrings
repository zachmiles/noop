    "Set a wake time for specific days — a lie-in at the weekend, say. Days you leave alone use the time above." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Legen Sie eine Weckzeit für bestimmte Tage fest – beispielsweise zum Ausschlafen am Wochenende. Tage, die Sie in Ruhe lassen, nutzen Sie die oben genannte Zeit."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Establezca una hora para despertarse para días específicos, por ejemplo, para descansar el fin de semana. Los días que dejas solo usa el tiempo anterior."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Установите время пробуждения для определенных дней — скажем, для лежания на выходных. В дни, когда вы остаетесь одни, используйте время, указанное выше."
          }
        }
      }
    },
