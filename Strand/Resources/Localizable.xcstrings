    "Entered together; stored as two markers so each lines up cleanly against your signals." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Gemeinsam eingetreten; werden als zwei Markierungen gespeichert, sodass jede genau an Ihren Signalen ausgerichtet ist."
          }
        },
        "es" : {
          "stringUnit" : {
