      }
    },
    "Connect your strap — Calm me is a felt rhythm on the wrist, so it needs a bonded connection." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verbinden Sie Ihren Riemen – „Calm me“ ist ein gefühlter Rhythmus am Handgelenk und benötigt daher eine feste Verbindung."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Conecta tu correa: Calm me es un ritmo que se siente en la muñeca, por lo que necesita una conexión unida."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Подсоедините ремешок. Calm me — это ритм, ощущаемый на запястье, поэтому требуется надежное соединение."
          }
        }
      }
    },
    "Connect your strap first — the reading needs the live R-R stream." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
