    "Recovery" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Erholung"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recuperación"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Восстановление"
          }
        }
      }
    },
    "Recovery weighs your HRV against your personal baseline (~60%), resting heart rate (~20%), sleep performance (~15%) and respiration (~5%). Day strain is a 0–21 cardiovascular load from time in heart-rate zones. Sleep is staged from movement and heart rate. Everything is computed here from the strap's raw data — it works for any day NOOP collected raw streams." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die Erholung gewichtet deine HRV gegenüber deiner persönlichen Basislinie (~60 %), die Ruheherzfrequenz (~20 %), die Schlafleistung (~15 %) und die Atmung (~5 %). Die Tagesbelastung ist eine kardiovaskuläre Last von 0–21 aus der Zeit in Herzfrequenzzonen. Der Schlaf wird aus Bewegung und Herzfrequenz in Phasen eingeteilt. Alles wird hier aus den Rohdaten des Straps berechnet — es funktioniert für jeden Tag, an dem NOOP Rohdaten erfasst hat."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Recovery weighs your HRV against your personal baseline (~60%), resting heart rate (~20%), sleep performance (~15%) and respiration (~5%). Day strain is a 0–21 cardiovascular load from time in heart-rate zones. Sleep is staged from movement and heart rate. Everything is computed here from the strap's raw data — it works for any day NOOP collected raw streams."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La recuperación compara su HRV con su línea de base personal (~60%), frecuencia cardíaca en reposo (~20%), rendimiento del sueño (~15%) y respiración (~5%). La tensión diurna es una carga cardiovascular de 0 a 21 por hora en zonas de frecuencia cardíaca. El sueño se organiza a partir del movimiento y la frecuencia cardíaca. Todo se calcula aquí a partir de los datos sin procesar de la correa: funciona para cualquier día que NOOP recopile transmisiones sin procesar."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Восстановление рассчитывается на основе вашей ВСР относительно личной нормы (~60%), пульса в покое (~20%), качества сна (~15%) и частоты дыхания (~5%). Дневная нагрузка — это сердечно-сосудистая нагрузка от 0 до 21, рассчитанная по времени в пульсовых зонах. Стадии сна определяются по движению и пульсу. Всё рассчитывается здесь, на основе исходных данных браслета, и работает для любого дня, когда NOOP собирал исходные потоки данных."
          }
        }
      }
    },
    "Reference range from your own report, optional" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Referenzbereich aus Ihrem eigenen Bericht, optional"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rango de referencia de su propio informe, opcional"
