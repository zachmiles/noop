    "“Dose” here is timing (later in the day = stronger), not milligrams." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "„Dosis“ bezieht sich hier auf das Timing (später am Tag = stärker), nicht auf Milligramm."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "La “dosis” aquí es el momento (más tarde en el día = más fuerte), no miligramos."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "«Доза» здесь — это время (позже в тот же день = сильнее), а не миллиграммы."
          }
        }
      }
    },
