    "Rhythm" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Rhythmus"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ritmo"
          }
        },
        "ru" : {
