    "Sit still and breathe with the buzz. You can stop anytime; a stopped sweep won't lock a pace." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sitzen Sie still und atmen Sie mit dem Summen. Sie können jederzeit aufhören; Ein gestoppter Sweep wird kein Tempo bremsen."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Siéntate quieto y respira con el zumbido. Puedes parar en cualquier momento; un barrido detenido no bloqueará el ritmo."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сидите спокойно и дышите с кайфом. Вы можете остановиться в любой момент; остановленная развертка не зафиксирует темп."
          }
        }
      }
    },
