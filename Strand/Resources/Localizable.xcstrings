    "Move all your NOOP data to another machine. Export saves everything — history, sleeps, workouts, settings — to a single file you can copy across; import replaces %@'s data with a backup." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Verschieben Sie alle Ihre NOOP-Daten auf einen anderen Computer. Beim Exportieren wird alles – Verlauf, Schlafzeiten, Trainingseinheiten, Einstellungen – in einer einzigen Datei gespeichert, die Sie kopieren können. Der Import ersetzt die Daten von%@ durch ein Backup."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mueva todos sus datos NOOP a otra máquina. La exportación guarda todo (historial, horas de sueño, entrenamientos, configuraciones) en un solo archivo que puede copiar; import reemplaza los datos de%@ con una copia de seguridad."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Переместите все данные NOOP на другой компьютер. Экспорт сохраняет все — историю, сон, тренировки, настройки — в один файл, который можно копировать; import заменяет данные%@ резервной копией."
          }
        }
      }
    },
    "Move all your NOOP data to another machine. Export saves everything — history, sleeps, workouts, settings — to a single file you can copy across; import replaces this Mac's data with a backup." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Übertrage alle deine NOOP-Daten auf einen anderen Rechner. Der Export speichert alles — Historie, Schlafphasen, Workouts, Einstellungen — in einer einzelnen Datei, die du kopieren kannst; der Import ersetzt die Daten dieses Macs durch eine Sicherung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Move all your NOOP data to another machine. Export saves everything — history, sleeps, workouts, settings — to a single file you can copy across; import replaces this Mac's data with a backup."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mueva todos sus datos NOOP a otra máquina. La exportación guarda todo (historial, horas de sueño, entrenamientos, configuraciones) en un solo archivo que puede copiar; import reemplaza los datos de este Mac con una copia de seguridad."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Перенесите все данные NOOP на другой компьютер. Экспорт сохраняет всё — историю, данные о сне, тренировки и настройки — в один файл, который можно скопировать на другое устройство. При импорте данные на этом Mac заменяются данными из резервной копии."
          }
        }
      }
    },
