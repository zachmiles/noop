    "e.g. Running" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "z.B. Laufen"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "por ej. corriendo"
          }
        },
        "ru" : {
