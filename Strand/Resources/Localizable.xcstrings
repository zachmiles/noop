          }
        }
      }
    },
    "Opens the GitHub releases page in your browser. NOOP itself makes no network connections — the macOS sandbox has no network entitlement." : {
      "extractionState" : "stale",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Öffnet die GitHub-Releases-Seite in deinem Browser. NOOP selbst stellt keine Netzwerkverbindungen her — die macOS-Sandbox hat keine Netzwerk-Berechtigung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Opens the GitHub releases page in your browser. NOOP itself makes no network connections — the macOS sandbox has no network entitlement."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Abre la página de lanzamientos de GitHub en su navegador. NOOP en sí no realiza conexiones de red: el entorno limitado de macOS no tiene derechos de red."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Откроет страницу релизов GitHub в браузере. Сам NOOP не устанавливает сетевые соединения — у песочницы macOS нет разрешения на доступ к сети."
          }
