            "value" : "Noch keine Workouts. Sie stammen aus deinem WHOOP- und Apple-Health-Verlauf. Importiere sie unter Datenquellen."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No workouts yet. They come from your WHOOP and Apple Health history. Import in Data Sources to bring them in."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún no hay entrenamientos. Provienen de su historial WHOOP y Apple Health. Importe fuentes de datos para incorporarlas."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Они берутся из истории WHOOP и Apple Здоровье. Импортируйте данные в разделе «Источники данных»."
          }
        }
      }
    },
    "Non-binary" : {
