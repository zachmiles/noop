android/.gradle/
android/build/
android/app/build/
android/captures/
android/local.properties
android/.idea/
android/*.iml
android/app/release/
*.apk
*.aab
*.keystore
*.jks

# ── IDE / editor ────────────────────────────────────────────────
.idea/
.vscode/
*.iml

# ── Misc / secrets (never commit) ───────────────────────────────
*.log
.env
# Deployment credentials (PAT / signing / endpoints) — never commit. `.env` above
# won't match `deploy.env`, so list it (and any `deploy.env.<stage>`) explicitly.
deploy.env
deploy.env.*
secrets.*
android/local.properties
android/keystore.properties
android/noop-release.jks

# ── Personal data — NEVER publish (real WHOOP/Apple Health exports) ──
Fixtures/
*.sqlite
*.sqlite-wal
*.sqlite-shm
export.xml
export.zip
*whoop_export*.zip
*apple_health*.zip

# Python bytecode
__pycache__/
*.pyc

# Local release artifacts (zips/ipas built for upload; never tracked)
dist/
err.txt
